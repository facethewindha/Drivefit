# Step 2：GeometryEncoder

**目标**：把源图的边缘/结构信息编码为 DiT 可用的条件

### 新建文件

[models/geometry_encoder.py](file:///d:/Reproduce/DriveFit/DriveDiTFit/models/geometry_encoder.py)

```python
import torch
import torch.nn as nn
import torch.nn.functional as F


class SobelExtractor(nn.Module):
    """从图片提取 Sobel 边缘（不可训练，推理时用）"""
    def __init__(self):
        super().__init__()
        sobel_x = torch.tensor([[-1, 0, 1], [-2, 0, 2], [-1, 0, 1]], 
                               dtype=torch.float32).view(1, 1, 3, 3)
        sobel_y = torch.tensor([[-1, -2, -1], [0, 0, 0], [1, 2, 1]], 
                               dtype=torch.float32).view(1, 1, 3, 3)
        # 3 通道各自检测边缘
        self.register_buffer('sobel_x', sobel_x.repeat(3, 1, 1, 1))
        self.register_buffer('sobel_y', sobel_y.repeat(3, 1, 1, 1))
    
    def forward(self, x):
        """x: (B, 3, H, W) → edge: (B, 1, H, W)"""
        edge_x = F.conv2d(x, self.sobel_x, padding=1, groups=3)
        edge_y = F.conv2d(x, self.sobel_y, padding=1, groups=3)
        edge = torch.sqrt(edge_x ** 2 + edge_y ** 2 + 1e-6)
        edge = edge.mean(dim=1, keepdim=True)  # 3通道取平均 → 1通道
        return edge


class GeometryEncoder(nn.Module):
    """
    将几何先验 map 编码为 DiT 的条件
    
    V0: 输入只有 Sobel 边缘 (1通道)
    V1: 可扩展为多通道 (edge + depth + seg + lane + drivable)
    
    输出两个:
      geo_embed:  (B, hidden_size)              → 加到全局条件 c 上
      geo_tokens: (B, num_patches, hidden_size)  → 加到 patch tokens 上
    """
    def __init__(self, in_channels=1, hidden_size=1152, latent_size=32, patch_size=2):
        super().__init__()
        self.hidden_size = hidden_size
        
        # 下采样: (B, in_ch, 256, 256) → (B, 256, 32, 32) → (B, hidden, 16, 16)
        self.encoder = nn.Sequential(
            nn.Conv2d(in_channels, 64, 3, stride=2, padding=1),   # → 128
            nn.GroupNorm(8, 64),
            nn.SiLU(),
            nn.Conv2d(64, 128, 3, stride=2, padding=1),           # → 64
            nn.GroupNorm(8, 128),
            nn.SiLU(),
            nn.Conv2d(128, 256, 3, stride=2, padding=1),          # → 32
            nn.GroupNorm(8, 256),
            nn.SiLU(),
            nn.Conv2d(256, hidden_size, patch_size, stride=patch_size),  # → 16
        )
        
        # 全局条件: pool → MLP → (B, hidden_size)
        self.global_mlp = nn.Sequential(
            nn.AdaptiveAvgPool2d(1),
            nn.Flatten(),
            nn.Linear(hidden_size, hidden_size),
            nn.SiLU(),
            nn.Linear(hidden_size, hidden_size),
        )
    
    def forward(self, geo_map):
        """
        geo_map: (B, in_channels, 256, 256)  几何先验图
        
        Returns:
            geo_embed:  (B, hidden_size)       全局几何向量
            geo_tokens: (B, 256, hidden_size)  空间几何 token
        """
        feat = self.encoder(geo_map)                       # (B, hidden_size, 16, 16)
        geo_tokens = feat.flatten(2).transpose(1, 2)       # (B, 256, hidden_size)
        geo_embed = self.global_mlp(feat)                  # (B, hidden_size)
        return geo_embed, geo_tokens
```

同时新建 [models/\_\_init\_\_.py](file:///d:/Reproduce/DriveFit/DriveDiTFit/models/__init__.py)：

```python
from .geometry_encoder import GeometryEncoder, SobelExtractor
```

